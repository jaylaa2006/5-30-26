# Per Ankh Reader — environment variable reference
# Copy to .env and fill in values before running locally or deploying.

# ── Core ──────────────────────────────────────────────────────────────────
PORT=3456
NODE_ENV=development

# ── Auth / Security ───────────────────────────────────────────────────────
JWT_SECRET=
AUTH_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ── SendGrid ──────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SEBA_FROM_EMAIL=seba@osiriscare.net

# ── Azure Speech ──────────────────────────────────────────────────────────
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# ── Gemini (seba-story-api.mjs) ───────────────────────────────────────────
GEMINI_API_KEY=

# ── Seba API signing secrets (boot-blocking in NODE_ENV=production) ───────
UNSUB_SECRET=
CHUNK_SIGNING_SECRET=

# ── Web Push (VAPID) ──────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Database ──────────────────────────────────────────────────────────────
SEBA_DB_PATH=./data/users.db

# ── F5 Wedeha PHOTO_IRI — boot-blocking in NODE_ENV=production ───────────
PHOTO_ENCRYPTION_KEY=  # 32 hex bytes (64 hex chars). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHOTO_HASH_SALT=       # random 32+ char string for userId hashing
PHOTOS_ROOT=/var/www/perankh/photos
