#!/usr/bin/env bash
# Per Ankh Reader — pre-commit hook
# Enforces .claude/rules/two-stage-qa-protocol.md "mandatory pre-commit
# verification" binding. Runs the test suites relevant to the files in
# this commit. Subagents and contributors that try to skip the binding
# get caught at git-commit time, not at CI-red time.
#
# Bypass: set NO_VERIFY=1 in env, or `git commit --no-verify` (per the
# project rule, only allowed when the user explicitly requests).

set -e

if [ "${NO_VERIFY:-}" = "1" ]; then
  echo "[pre-commit] NO_VERIFY=1 — skipping mandatory pre-commit verification"
  exit 0
fi

changed=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$changed" ]; then
  exit 0
fi

# Map changed files to required test suites. Each line: "pattern test_script"
# Pattern is a substring match against the changed file path.
run_tests=()
add_test() {
  for t in "${run_tests[@]}"; do
    if [ "$t" = "$1" ]; then return; fi
  done
  run_tests+=("$1")
}

while IFS= read -r f; do
  case "$f" in
    senebty/lib/foundation-render.js|tests/senebty-foundation-render*.test.mjs|tests/senebty-foundation-pulse.test.mjs|tests/senebty-foundation-reflection.test.mjs)
      add_test "test:senebty-foundation-render"
      add_test "test:senebty-foundation-render-html-wiring"
      add_test "test:senebty-foundation-pulse"
      add_test "test:senebty-foundation-reflection"
      add_test "test:senebty-class-coverage"
      ;;
    senebty/data/foundations/01-mu/story.js|tests/senebty-foundation-mu-data.test.mjs)
      # F1 Mu story.js changes → run pulse + reflection + F1 data test + screen + html-wiring tests
      add_test "test:senebty-foundation-pulse"
      add_test "test:senebty-foundation-reflection"
      add_test "test:senebty-foundation-mu-data"
      add_test "test:senebty-daily-foundation-screen"
      add_test "test:senebty-daily-foundation-html-wiring"
      ;;
    senebty/data/foundations/02-four-treasures/story.js|tests/senebty-foundation-four-treasures-data.test.mjs)
      # F2 Four Treasures story.js changes → run pulse + reflection + F2 data test + screen + html-wiring tests
      # Stage-2 Coach C3: html-wiring added so installer + load-order
      # regressions (Rule 6) are caught at commit-time, not at deploy-time.
      add_test "test:senebty-foundation-pulse"
      add_test "test:senebty-foundation-reflection"
      add_test "test:senebty-foundation-four-treasures-data"
      add_test "test:senebty-daily-foundation-screen"
      add_test "test:senebty-daily-foundation-html-wiring"
      ;;
    senebty/data/foundations/03-tjau/story.js|tests/senebty-foundation-tjau-data.test.mjs)
      # F3 Tjau story.js changes → run pulse + reflection + F3 data test + screen + html-wiring tests
      add_test "test:senebty-foundation-pulse"
      add_test "test:senebty-foundation-reflection"
      add_test "test:senebty-foundation-tjau-data"
      add_test "test:senebty-daily-foundation-screen"
      add_test "test:senebty-daily-foundation-html-wiring"
      ;;
    senebty/data/foundations/04-mu-streak/story.js|tests/senebty-foundation-mu-streak-data.test.mjs)
      # F4 Mu Streak story.js changes → run pulse + reflection + F4 data test + screen + html-wiring tests
      add_test "test:senebty-foundation-pulse"
      add_test "test:senebty-foundation-reflection"
      add_test "test:senebty-foundation-mu-streak-data"
      add_test "test:senebty-daily-foundation-screen"
      add_test "test:senebty-daily-foundation-html-wiring"
      ;;
    senebty/data/foundations/05-wedeha/story.js|tests/senebty-foundation-wedeha-data.test.mjs)
      # F5 Wedeha story.js changes → run pulse + reflection + F5 data test + screen + html-wiring tests
      add_test "test:senebty-foundation-pulse"
      add_test "test:senebty-foundation-reflection"
      add_test "test:senebty-foundation-wedeha-data"
      add_test "test:senebty-daily-foundation-screen"
      add_test "test:senebty-daily-foundation-html-wiring"
      ;;
    senebty/data/foundations/06-hesi/story.js|tests/senebty-foundation-hesi-data.test.mjs)
      # F6 Hesi story.js changes → run pulse + reflection + F6 data test + screen + html-wiring tests
      add_test "test:senebty-foundation-pulse"
      add_test "test:senebty-foundation-reflection"
      add_test "test:senebty-foundation-hesi-data"
      add_test "test:senebty-daily-foundation-screen"
      add_test "test:senebty-daily-foundation-html-wiring"
      ;;
    senebty/data/foundations/07-senedjem/story.js|tests/senebty-foundation-senedjem-data.test.mjs)
      # F7 Senedjem story.js changes → run pulse + reflection + F7 data test + screen + html-wiring tests
      add_test "test:senebty-foundation-pulse"
      add_test "test:senebty-foundation-reflection"
      add_test "test:senebty-foundation-senedjem-data"
      add_test "test:senebty-daily-foundation-screen"
      add_test "test:senebty-daily-foundation-html-wiring"
      ;;
    senebty/data/foundations/08-heka/story.js|tests/senebty-foundation-heka-data.test.mjs)
      # F8 Heka story.js changes → run pulse + reflection + F8 data test + screen + html-wiring tests
      add_test "test:senebty-foundation-pulse"
      add_test "test:senebty-foundation-reflection"
      add_test "test:senebty-foundation-heka-data"
      add_test "test:senebty-daily-foundation-screen"
      add_test "test:senebty-daily-foundation-html-wiring"
      ;;
    senebty/data/foundations/01-mu/*|senebty/data/foundations/02-four-treasures/*)
      # Other assets (images, etc.) under those dirs still get pulse + reflection
      add_test "test:senebty-foundation-pulse"
      add_test "test:senebty-foundation-reflection"
      ;;
    senebty/lib/daily-foundation-screen.js|senebty/styles/daily-foundation.css)
      # daily-foundation engine or CSS changes → run F1-F7 data tests + screen + html-wiring tests
      # Stage-2 Coach C3: html-wiring added (Rule 6 installer load-order).
      add_test "test:senebty-foundation-mu-data"
      add_test "test:senebty-foundation-four-treasures-data"
      add_test "test:senebty-foundation-tjau-data"
      add_test "test:senebty-foundation-mu-streak-data"
      add_test "test:senebty-foundation-wedeha-data"
      add_test "test:senebty-foundation-hesi-data"
      add_test "test:senebty-foundation-senedjem-data"
      add_test "test:senebty-foundation-heka-data"
      add_test "test:senebty-daily-foundation-screen"
      add_test "test:senebty-daily-foundation-html-wiring"
      ;;
    senebty/lib/parent-dashboard.js|tests/senebty-parent-dashboard*.test.mjs)
      add_test "test:senebty-parent-dashboard"
      ;;
    senebty/lib/daily-ritual.js|tests/senebty-daily-ritual*.test.mjs)
