      ;;
    senebty/lib/tier-modal.js|senebty/lib/tiers.js|tests/senebty-tier-modal*.test.mjs)
      add_test "test:senebty-tier-modal"
      ;;
    server.js|tests/auth*.test.mjs)
      add_test "test:auth-password-reset"
      add_test "test:auth-funnel-digest"
      add_test "test:auth-stop-the-bleed"
      add_test "test:google-oauth-audit"
      add_test "test:email-capture"
      add_test "test:speech-token-resilience"
      add_test "test:yt-dlp-resolver"
      ;;
    tests/speech-token-resilience.test.mjs)
      add_test "test:speech-token-resilience"
      ;;
    tests/yt-dlp-resolver.test.mjs)
      add_test "test:yt-dlp-resolver"
      ;;
    tests/google-oauth-audit.test.mjs)
      add_test "test:google-oauth-audit"
      ;;
    emails/*|scripts/send-seba-weekly.mjs|tests/seba-weekly-broadcast.test.mjs)
      add_test "test:seba-weekly-broadcast"
      ;;
    seba-story-api.mjs|tests/seba-output-screen.test.mjs)
      add_test "test:seba-output-screen"
      add_test "test:email-capture"
      add_test "test:seba-sync-merge"
      # 2026-05-23 DEMETRIS remediation — bounded-retry email send + visibility.
      add_test "test:email-retry"
      add_test "test:email-send-retry-wiring"
      add_test "test:welcome-email-backfill"
      add_test "test:auth-stop-the-bleed"
      add_test "test:auth-funnel-digest"
      # v3.51.73 — Response Log content discipline (insertReflection guard +
      # weekly-email filter); maat-reader.html branch below adds the
      # client-side coverage.
      add_test "test:response-log-content-discipline"
      ;;
    lib/email-retry.mjs|tests/email-retry.test.mjs|tests/email-send-retry-wiring.test.mjs)
      add_test "test:email-retry"
      add_test "test:email-send-retry-wiring"
      ;;
    lib/merge-user-data.mjs|tests/seba-sync-merge.test.mjs)
      add_test "test:seba-sync-merge"
      ;;
    # v3.51.74 — SW deploy-path discipline. server.js or sw.js touched →
    # run the shadow-path contract test (catches reinstated dead route +
    # any new repo-root sw.js + static-mount ordering regression).
    server.js|public/sw.js|tests/sw-deploy-path.test.mjs)
      add_test "test:sw-deploy-path"
      ;;
    # v3.51.75 — Landing + login bundle (loading state, USE_GOOGLE hint,
    # role=alert, hero Sign In, register-default, loud catches, auto-scroll).
    # Triggered on any auth-surface change so the contract holds.
    server.js|maat-reader.html|tests/landing-login-bundle.test.mjs)
      add_test "test:landing-login-bundle"
      ;;
    # v3.51.76 — Defensive UX + security (U3 show/hide pw, U4 caps-lock,
    # S2 email char-strip reject, S3 name length cap).
    server.js|maat-reader.html|tests/landing-login-defensive-bundle.test.mjs)
      add_test "test:landing-login-defensive-bundle"
      ;;
    # v3.51.77 — Audit follow-up bundle (U5 contrast, R2 JWT-on-auth,
    # M2 GSI-blocked fallback, P3 sample story link).
    maat-reader.html|tests/landing-login-followup-bundle.test.mjs)
      add_test "test:landing-login-followup-bundle"
      ;;
    # v3.51.78 — Landing SEO bundle (title + meta + h1 + Featured Stories).
    maat-reader.html|tests/landing-seo-bundle.test.mjs)
      add_test "test:landing-seo-bundle"
      ;;
    senebty/lib/*.js|senebty/styles/senebty.css|tests/senebty-*.test.mjs)
      add_test "test:senebty-class-coverage"
      ;;
    # v3.51.45 — landing-page video efficiency contract. Triggered by any
    # change touching maat-reader.html (where the IIFE + <video> tags live),
    # the landing-video re-encode script, posters, or the test itself.
    maat-reader.html|tests/landing-video-efficiency.test.mjs|scripts/encode-landing-videos.sh|public/images/landing/*)
      add_test "test:landing-video-efficiency"
      add_test "test:google-oauth-audit"
      add_test "test:yw-mobile-scroll"
      add_test "test:seba-sync-merge"
      add_test "test:parent-pin-self-heal"
      # v3.51.73 — Response Log discipline (logResponse callsites +
      # _fetchServerReflections loud-fail + banner + retry + auth headers).
      add_test "test:response-log-content-discipline"
      ;;
  esac
done <<< "$changed"

if [ ${#run_tests[@]} -eq 0 ]; then
  exit 0
fi

echo "[pre-commit] Running ${#run_tests[@]} test suite(s) before commit:"
for t in "${run_tests[@]}"; do echo "  - npm run $t"; done

for t in "${run_tests[@]}"; do
  if ! npm run "$t" --silent > /tmp/pre-commit-test.log 2>&1; then
    echo "[pre-commit] FAILED: npm run $t"
    tail -30 /tmp/pre-commit-test.log
    echo ""
    echo "[pre-commit] Commit blocked. Fix the failure above or set NO_VERIFY=1"
    echo "[pre-commit] (per .claude/rules/two-stage-qa-protocol.md mandatory binding)."
    exit 1
  fi
  echo "[pre-commit] OK: npm run $t"
done

echo "[pre-commit] All required tests passed."
exit 0
